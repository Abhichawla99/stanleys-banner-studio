{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "server",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["--env-file=.env", "server/index.mjs"],
      "port": 3001
    },
    {
      "name": "client",
      "runtimeExecutable": "/opt/homebrew/bin/npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000,
      "autoPort": true,
      "cwd": "client"
    }
  ]
}
