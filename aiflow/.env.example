# AIFlow server environment variables
# Copy this file to .env and fill in your API keys
# Keys set here take priority over the Settings panel in the browser

# Google Gemini API key (Nano Banana 2, Imagen 4, LLM, Veo 3.1, Image Describer)
GEMINI_API_KEY=

# OpenAI API key (GPT-4o, GPT-4o-mini, GPT Image 1)
OPENAI_API_KEY=

# fal.ai API key (Flux, Recraft, Ideogram, Nano Banana 2 via fal)
FAL_API_KEY=

# Kling AI keys (JWT signed server-side when set here)
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
