{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/:path*",       "destination": "/api/index.mjs" },
    { "source": "/outputs/:path*",   "destination": "/api/index.mjs" },
    { "source": "/templates/:path*", "destination": "/api/index.mjs" },
    { "source": "/(.*)",             "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "memory": 1024,
      "maxDuration": 300
    }
  }
}
