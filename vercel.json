{
  "version": 2,
  "buildCommand": "cd client && npm install && npm run build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server/index.mjs" },
    { "source": "/outputs/(.*)", "destination": "/server/index.mjs" },
    { "source": "/templates/(.*)", "destination": "/server/index.mjs" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "functions": {
    "server/index.mjs": {
      "memory": 1024,
      "maxDuration": 300
    }
  }
}
